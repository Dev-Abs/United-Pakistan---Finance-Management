{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/login.html",
      "dest": "public/login.html"
    },
    {
      "src": "/(.*\\.(?:html|css|js|json|svg|png|ico))",
      "dest": "public/$1"
    },
    {
      "src": "/sw.js",
      "dest": "public/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "server/index.js"
    }
  ]
}
